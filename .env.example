# LinkedIn OAuth credentials
# Obtain from https://developer.linkedin.com — your app's Auth tab
LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# Redirect URI registered in your LinkedIn app
LINKEDIN_REDIRECT_URI=http://localhost:8080/callback

# Path to Hugo site content directory (relative to linkedin-publisher/)
HUGO_CONTENT_PATH=../site/content/blog
